@model FeatureCard
@{
    string blobClasses;
    string badgeClasses;

    switch (Model.Color)
    {
        case FeatureCardColor.Sky:
            blobClasses = "bg-sky-500/10 group-hover:bg-sky-500/20";
            badgeClasses = "bg-sky-500/15 ring-sky-400/30 text-sky-300";
            break;
        case FeatureCardColor.Fuchsia:
            blobClasses = "bg-fuchsia-500/10 group-hover:bg-fuchsia-500/20";
            badgeClasses = "bg-fuchsia-500/15 ring-fuchsia-400/30 text-fuchsia-300";
            break;
        case FeatureCardColor.Amber:
            blobClasses = "bg-amber-500/10 group-hover:bg-amber-500/20";
            badgeClasses = "bg-amber-500/15 ring-amber-400/30 text-amber-300";
            break;
        default:
            blobClasses = "bg-emerald-500/10 group-hover:bg-emerald-500/20";
            badgeClasses = "bg-emerald-500/15 ring-emerald-400/30 text-emerald-300";
            break;
    }
}

<div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-neutral-900 to-neutral-900/40 p-8 transition hover:border-purple-500/40 hover:bg-neutral-900">
    <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full blur-3xl transition @blobClasses"></div>
    <div class="relative">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl ring-1 mb-5 @badgeClasses">
            @if (!Model.IsSlotContentNullOrEmpty(FeatureCard.IconSlot))
            {
                @Model.RenderSlot(FeatureCard.IconSlot)
            }
        </div>
        <h3 class="text-xl font-semibold text-white">@Model.Title</h3>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="mt-3 text-neutral-400">@Model.Description</p>
        }

        @if(!Model.IsChildContentNullOrEmpty)
        {
            @Model.ChildContent
        }
    </div>
</div>
