<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PokeBinder</title>
    <pines-css />
    <link rel="stylesheet" href="~/css/site.tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PokeBinder.styles.css" asp-append-version="true" />
</head>
<body class="bg-white antialiased">

    @* Top navigation bar *@
    <pines-navbar home-route="/">
        <slot name="nav-links">
            <pines-sidebar-link asp-page="/Index">Home</pines-sidebar-link>
        </slot>
        <slot name="user-area">
            <partial name="_LoginPartial" />
        </slot>
    </pines-navbar>

    @* Page body: sidebar + main content *@
    <div class="relative flex items-start min-h-screen px-4 pt-0 pb-0 mx-auto mt-16 max-w-7xl">

        @* Mobile overlay to close sidebar *@
        <pines-backdrop-blur></pines-backdrop-blur>

        @* Left sidebar *@
        <pines-sidebar>
            <pines-sidebar-section section-name="Card Search">
                <pines-sidebar-link asp-page="/Index">Home</pines-sidebar-link>
                <pines-sidebar-link asp-page="/CardSearch">Installation</pines-sidebar-link>
            </pines-sidebar-section>
            <pines-sidebar-section section-name="Binders">
                <pines-sidebar-link asp-page="/Components/my-binders">My Binders</pines-sidebar-link>
            </pines-sidebar-section>
        </pines-sidebar>

        @* Main content area — offset by sidebar width on large screens *@
        <main role="main" class="flex-1 w-full min-w-0 pl-0 lg:pl-63 pb-16 pt-5">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
    <pines-scripts />
    <render-static-scripts />

    
</body>
</html>
