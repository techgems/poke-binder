@page
@model IndexModel
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Digital binders for the Pokémon TCG";
    ViewData["Description"] = "PokeBinder turns your Pokémon TCG collection into beautiful digital binders with live market values, instant sharing, and a near-complete catalog of every Pokémon card ever printed.";
}

@* Transparent landing header *@
<landing-header>
    <slot name="@LandingHeader.LogoSlot">
        <a asp-page="/Index" class="flex items-center gap-2" aria-label="PokeBinder home">
            <img src="~/images/TCG Forge First Draft.png"
                 alt="PokeBinder"
                 class="h-10 w-auto drop-shadow-[0_0_20px_rgba(168,85,247,0.35)]" />
        </a>
    </slot>
    <slot name="@LandingHeader.OptionsSlot">
        <a asp-page="/Account/Login"
           class="inline-flex items-center justify-center rounded-xl border border-white/15 bg-white/5 px-5 py-2 text-sm font-semibold text-white backdrop-blur-sm transition hover:bg-white/10">
            Sign in
        </a>
    </slot>
</landing-header>

@* Full-bleed dark landing page *@
<main role="main" class="relative w-full bg-neutral-950 text-neutral-100 overflow-hidden">

    @* ================= HERO ================= *@
    <section class="relative isolate min-h-[calc(100vh-4rem)] flex items-center justify-center overflow-hidden">

        @* --- Backdrop: alternating rows of sliding pokemon cards --- *@
        <div aria-hidden="true" class="absolute inset-0 -z-10 select-none">

            <hero-card-rows-component></hero-card-rows-component>

            @* Vignette + radial wash *@
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(59,7,100,0.45),rgba(10,10,10,0)_60%)]"></div>
            <div class="absolute inset-0 bg-gradient-to-b from-neutral-950/60 via-neutral-950/30 to-neutral-950"></div>

            @* Decorative glow blobs *@
            <div class="absolute -top-24 -left-24 h-96 w-96 rounded-full bg-purple-600/30 blur-3xl animate-pulse-glow"></div>
            <div class="absolute -bottom-32 -right-24 h-[28rem] w-[28rem] rounded-full bg-sky-500/20 blur-3xl animate-pulse-glow"></div>
        </div>

        @* --- Hero content --- *@
        <div class="relative z-10 mx-auto max-w-4xl px-6 py-24 text-center">

            <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium text-purple-200 backdrop-blur-sm mb-6">
                <span class="h-1.5 w-1.5 rounded-full bg-purple-400 animate-pulse"></span>
                Digital binders for the Pokémon TCG
            </div>

            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-white leading-[1.05]">
                <pines-text-animation animation-type="SlideUp">
                    Build, value, and share your Pokémon collection.
                </pines-text-animation>
            </h1>

            <p class="mt-6 text-lg sm:text-xl text-neutral-300 max-w-2xl mx-auto">
                PokeBinder turns your collection into beautiful digital binders — with live market values, instant sharing, and a near-complete catalog of every Pokémon card ever printed.
            </p>

            <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
                <primary-cta-button page="/CardSearch">Search Cards</primary-cta-button>
                <primary-cta-button page="/Account/Login" variant="Outline">Get Started — it's free</primary-cta-button>
            </div>

            <div class="mt-12 flex items-center justify-center gap-8 text-xs text-neutral-400">
                <div class="flex items-center gap-2">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                    Near-complete card database
                </div>
                <div class="hidden sm:flex items-center gap-2">
                    <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                    Live market pricing
                </div>
                <div class="hidden md:flex items-center gap-2">
                    <span class="h-1.5 w-1.5 rounded-full bg-sky-400"></span>
                    Share with a link
                </div>
            </div>
        </div>
    </section>

    @* ================= FEATURES ================= *@
    <section id="features" class="relative py-24 sm:py-32 px-6">
        <div class="mx-auto max-w-7xl">

            <div class="mx-auto max-w-2xl text-center">
                <p class="text-sm font-semibold uppercase tracking-widest text-purple-400">Everything you need</p>
                <h2 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-white">
                    A smarter way to organize your collection
                </h2>
                <p class="mt-5 text-lg text-neutral-400">
                    From quick searches to richly customizable binders, PokeBinder gives serious collectors the tools that physical binders never could.
                </p>
            </div>

            <div class="mt-20 grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">

                @* Feature 1: Market Value *@
                <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-neutral-900 to-neutral-900/40 p-8 transition hover:border-purple-500/40 hover:bg-neutral-900">
                    <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-emerald-500/10 blur-3xl transition group-hover:bg-emerald-500/20"></div>
                    <div class="relative">
                        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/15 ring-1 ring-emerald-400/30 text-emerald-300 mb-5">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
                            </svg>
                        </div>
                        <h3 class="text-xl font-semibold text-white">Live market value</h3>
                        <p class="mt-3 text-neutral-400">
                            Every binder shows the up-to-date market value of each card and the running total for the whole collection — so you always know what your shelves are really worth.
                        </p>
                    </div>
                </div>

                @* Feature 2: Shareability *@
                <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-neutral-900 to-neutral-900/40 p-8 transition hover:border-purple-500/40 hover:bg-neutral-900">
                    <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-sky-500/10 blur-3xl transition group-hover:bg-sky-500/20"></div>
                    <div class="relative">
                        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-sky-500/15 ring-1 ring-sky-400/30 text-sky-300 mb-5">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
                            </svg>
                        </div>
                        <h3 class="text-xl font-semibold text-white">Share with a single link</h3>
                        <p class="mt-3 text-neutral-400">
                            Send a friend, a trade partner, or a buyer a single link and let them flip through your binder exactly as you arranged it — no screenshots, no spreadsheets, no friction.
                        </p>
                    </div>
                </div>

                @* Feature 3: Custom binder sizes *@
                <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-neutral-900 to-neutral-900/40 p-8 transition hover:border-purple-500/40 hover:bg-neutral-900">
                    <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-fuchsia-500/10 blur-3xl transition group-hover:bg-fuchsia-500/20"></div>
                    <div class="relative">
                        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-fuchsia-500/15 ring-1 ring-fuchsia-400/30 text-fuchsia-300 mb-5">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                            </svg>
                        </div>
                        <h3 class="text-xl font-semibold text-white">Binders from 2×2 to 5×4</h3>
                        <p class="mt-3 text-neutral-400">
                            Match the real-world pages you carry, from compact 4-pocket binders all the way up to 20-pocket display sheets. Pick the grid that fits your collection's vibe.
                        </p>
                        <div class="mt-5 flex flex-wrap gap-2">
                            <span class="rounded-md bg-white/5 px-2 py-1 text-xs font-medium text-neutral-300 ring-1 ring-white/10">2×2</span>
                            <span class="rounded-md bg-white/5 px-2 py-1 text-xs font-medium text-neutral-300 ring-1 ring-white/10">3×3</span>
                            <span class="rounded-md bg-white/5 px-2 py-1 text-xs font-medium text-neutral-300 ring-1 ring-white/10">4×3</span>
                            <span class="rounded-md bg-white/5 px-2 py-1 text-xs font-medium text-neutral-300 ring-1 ring-white/10">5×4</span>
                        </div>
                    </div>
                </div>

                @* Feature 4: Ownership tracking *@
                <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-neutral-900 to-neutral-900/40 p-8 transition hover:border-purple-500/40 hover:bg-neutral-900">
                    <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-amber-500/10 blur-3xl transition group-hover:bg-amber-500/20"></div>
                    <div class="relative">
                        <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/15 ring-1 ring-amber-400/30 text-amber-300 mb-5">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        </div>
                        <h3 class="text-xl font-semibold text-white">Track what you own</h3>
                        <p class="mt-3 text-neutral-400">
                            Mark each slot as owned or missing and instantly see the gaps in your set. Build wishlists, plan trades, and chase completion without a single sticky note.
                        </p>
                    </div>
                </div>
            </div>

            @* Powered-by-search callout *@
            <div class="mt-20 relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-r from-purple-950/40 via-fuchsia-950/30 to-neutral-900 p-8 sm:p-12">
                <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-purple-500/20 blur-3xl"></div>
                <div class="relative flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
                    <div class="max-w-2xl">
                        <h3 class="text-2xl sm:text-3xl font-bold text-white">A search engine for every Pokémon card.</h3>
                        <p class="mt-3 text-neutral-300">
                            Filter by set, rarity, type, artist, or price. Our catalog covers nearly every card ever printed — from Base Set Charizards to the latest Scarlet &amp; Violet pulls.
                        </p>
                    </div>
                    <primary-cta-button page="/CardSearch" variant="White">Try the card search</primary-cta-button>
                </div>
            </div>
        </div>
    </section>

    @* ================= FOOTER STRIP ================= *@
    <footer class="border-t border-white/5 py-10 px-6">
        <div class="mx-auto max-w-7xl flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-neutral-500">
            <div class="flex items-center gap-3">
                <img src="~/images/TCG Forge First Draft.png" alt="PokeBinder" class="h-7 w-auto opacity-80" />
                <span>&copy; @DateTime.UtcNow.Year PokeBinder</span>
            </div>
            <div class="text-xs">
                Pokémon and all related trademarks are property of their respective owners. PokeBinder is a fan-made collection tool.
            </div>
        </div>
    </footer>
</main>
