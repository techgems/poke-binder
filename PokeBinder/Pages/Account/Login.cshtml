@page
@model PokeBinder.Pages.Account.LoginModel
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Sign in";
    ViewData["Description"] = "Sign in to PokeBinder with a one-time login link — no password required.";
}

@* Transparent landing header *@
<landing-header>
    <slot name="@LandingHeader.LogoSlot">
        <a asp-page="/Index" class="flex items-center gap-2" aria-label="PokeBinder home">
            <img src="~/images/TCG Forge First Draft.png"
                 alt="PokeBinder"
                 class="h-10 w-auto drop-shadow-[0_0_20px_rgba(168,85,247,0.35)]" />
        </a>
    </slot>
    <slot name="@LandingHeader.OptionsSlot">
        <a asp-page="/Index"
           class="inline-flex items-center justify-center rounded-xl border border-white/15 bg-white/5 px-5 py-2 text-sm font-semibold text-white backdrop-blur-sm transition hover:bg-white/10">
            Back to home
        </a>
    </slot>
</landing-header>

<main role="main" class="relative w-full min-h-screen bg-neutral-950 text-neutral-100 overflow-hidden flex items-center justify-center px-6 py-24">

    @* --- Backdrop glow --- *@
    <div aria-hidden="true" class="absolute inset-0 -z-10 select-none">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(59,7,100,0.45),rgba(10,10,10,0)_60%)]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-neutral-950/60 via-neutral-950/30 to-neutral-950"></div>
        <div class="absolute -top-24 -left-24 h-96 w-96 rounded-full bg-purple-600/30 blur-3xl animate-pulse-glow"></div>
        <div class="absolute -bottom-32 -right-24 h-[28rem] w-[28rem] rounded-full bg-sky-500/20 blur-3xl animate-pulse-glow"></div>
    </div>

    <div class="relative z-10 w-full max-w-md">

        @if (Model.ShowTokenSentMessage)
        {
            <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-neutral-900 to-neutral-900/40 p-8 sm:p-10 backdrop-blur-sm shadow-2xl shadow-purple-950/40 text-center">
                <div class="mx-auto mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-500/15 ring-1 ring-emerald-400/30 text-emerald-300">
                    <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                    </svg>
                </div>

                <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-white">
                    Check your inbox
                </h1>
                <p class="mt-3 text-neutral-300">
                    We've sent you a one-time login link. Click the link in the email to continue.
                </p>

                <a asp-page="/Account/Login"
                   class="mt-8 inline-flex items-center justify-center gap-2 rounded-xl border border-white/15 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition hover:bg-white/10">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                    </svg>
                    Use a different email
                </a>
            </div>
        }
        else
        {
            <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-neutral-900 to-neutral-900/40 p-8 sm:p-10 backdrop-blur-sm shadow-2xl shadow-purple-950/40">

                <div class="text-center">
                    <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium text-purple-200 backdrop-blur-sm mb-5">
                        <span class="h-1.5 w-1.5 rounded-full bg-purple-400 animate-pulse"></span>
                        Passwordless sign in
                    </div>

                    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-white leading-tight">
                        Welcome to PokeBinder
                    </h1>
                    <p class="mt-3 text-neutral-400">
                        Enter your email and we'll send you a one-time link to sign in or create your account.
                    </p>
                </div>

                <form method="post" class="mt-8 space-y-5">
                    <div asp-validation-summary="All" class="rounded-lg border border-rose-500/30 bg-rose-500/10 p-3 text-sm text-rose-200 empty:hidden"></div>

                    <div class="w-full">
                        <pines-input show-label="true" asp-for="Input.Email"></pines-input>
                        <span asp-validation-for="Input.Email" class="mt-1 block text-xs text-rose-300"></span>
                    </div>

                    <button type="submit"
                            class="group inline-flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-purple-500 to-fuchsia-500 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-purple-900/40 transition hover:from-purple-400 hover:to-fuchsia-400 hover:shadow-purple-700/50">
                        Send login link
                        <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                        </svg>
                    </button>
                </form>

                <p class="mt-6 text-center text-xs text-neutral-500">
                    By continuing you agree to our terms and acknowledge our privacy policy.
                </p>
            </div>

            <p class="mt-6 text-center text-sm text-neutral-400">
                New to PokeBinder?
                <span class="text-neutral-200">Just enter your email — we'll set up your account automatically.</span>
            </p>
        }
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
